  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cache hits (per-second, by pool)",
      "description": "rate(shelf_hits_total[1m]) — proves SHELF-06 is serving warm reads.",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum by (pool) (rate(shelf_hits_total[1m]))",
          "legendFormat": "hits — {{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cache misses (per-second, by pool)",
      "description": "rate(shelf_misses_total[1m]) — miss rate that fell through to S3.",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "sum by (pool) (rate(shelf_misses_total[1m]))",
          "legendFormat": "misses — {{pool}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 request latency (5m)",
      "description": "histogram_quantile(0.95, sum by (le) (rate(shelf_request_seconds_bucket[5m]))) — end-to-end HTTP latency.",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(shelf_request_seconds_bucket[5m])))",
          "legendFormat": "p95 — all paths",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(shelf_request_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{path}}",
          "refId": "B"
        }
      ]
    }
  ],
