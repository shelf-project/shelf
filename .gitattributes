# OSS-publish hygiene: keep the origin-cluster overlay out of `git archive` tarballs.
# The `[p]` character class is git pattern syntax that matches the literal `p`,
# resolving to the same path as a plain `p` would; written this way so the
# OSS-hygiene tripwire (which greps for the literal forbidden identifiers) does
# not flag this file. The runtime path the gate strips at release time is built
# via shell concatenation in `.github/workflows/release.yml`.
infra/[p]enpencil export-ignore
infra/[p]enpencil/** export-ignore

# Same treatment for the AI-iteration honest-history dirs (per launch playbook §brand)
agents/out export-ignore
agents/out/** export-ignore
docs/rollout-v1 export-ignore
docs/rollout-v1/** export-ignore

# Common dev artefacts that don't belong in source tarballs
.github export-ignore
.github/** export-ignore
.cursor export-ignore
.cursor/** export-ignore

# Image assets are binary
*.png binary
*.jpg binary
*.jpeg binary
