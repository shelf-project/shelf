{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Shelf cache overview — traffic-light health, per-pod hit rate, latency, fall-through, DRAM/NVMe usage. Source: BLUEPRINT §9.3, plan §6.4. Placeholder metric names (prefix shelf_*) will be emitted by shelfd; see docs/metrics.md (TBD).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"title": "Runbook: hit rate low",     "url": "https://github.com/shelf-project/shelf/blob/main/runbooks/shelf-hit-rate-too-low.md",  "type": "link", "icon": "external link"},
    {"title": "Runbook: fall-through",     "url": "https://github.com/shelf-project/shelf/blob/main/runbooks/shelf-fall-through-surge.md", "type": "link", "icon": "external link"},
    {"title": "Runbook: NVMe high",        "url": "https://github.com/shelf-project/shelf/blob/main/runbooks/shelf-nvme-usage-high.md",    "type": "link", "icon": "external link"},
    {"title": "Runbook: circuit breaker",  "url": "https://github.com/shelf-project/shelf/blob/main/runbooks/circuit-breaker-open.md",     "type": "link", "icon": "external link"}
  ],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cumulative hit rate (7d)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 0.6},
              {"color": "green",  "value": 0.71}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(rate(shelf_hits_total[7d])) / (sum(rate(shelf_hits_total[7d])) + sum(rate(shelf_misses_total[7d])))",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 read latency (HTTP)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 0.05},
              {"color": "red",    "value": 0.1}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(shelf_read_latency_seconds_bucket{transport=\"http2\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Fall-through rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 0.05},
              {"color": "red",    "value": 0.2}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "sum(rate(shelf_plugin_fallthrough_total[5m])) / sum(rate(shelf_plugin_requests_total[5m]))",
          "legendFormat": "fall-through",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Ready pods",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "orange", "value": 2},
              {"color": "green",  "value": 3}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {"expr": "kube_statefulset_status_replicas_ready{statefulset=\"shelf\"}", "refId": "A"}
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Per-pod hit rate",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [
        {
          "expr": "sum by (pod) (rate(shelf_hits_total[5m])) / (sum by (pod) (rate(shelf_hits_total[5m])) + sum by (pod) (rate(shelf_misses_total[5m])))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Read latency percentiles (HTTP/2)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(shelf_read_latency_seconds_bucket{transport=\"http2\"}[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(shelf_read_latency_seconds_bucket{transport=\"http2\"}[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(shelf_read_latency_seconds_bucket{transport=\"http2\"}[5m])))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "DRAM usage per pool per pod",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [
        {"expr": "sum by (pod, pool) (shelf_dram_bytes_used)", "legendFormat": "{{pod}}/{{pool}}", "refId": "A"}
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "NVMe usage per pod",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "max": 1}},
      "targets": [
        {
          "expr": "shelf_nvme_bytes_used / shelf_nvme_bytes_capacity",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Admission rate vs fall-through",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "fieldConfig": {"defaults": {"unit": "ops"}},
      "targets": [
        {"expr": "sum(rate(shelf_admissions_total[1m]))",            "legendFormat": "admit/s",         "refId": "A"},
        {"expr": "sum(rate(shelf_admission_refused_total[1m]))",     "legendFormat": "refuse/s",        "refId": "B"},
        {"expr": "sum(rate(shelf_plugin_fallthrough_total[1m]))",    "legendFormat": "fall-through/s",  "refId": "C"}
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Circuit breaker state (per pod)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
      "description": "0 = closed, 1 = half-open, 2 = open. See runbook 'circuit-breaker-open'.",
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "max": 2}},
      "targets": [
        {"expr": "shelf_circuit_breaker_state", "legendFormat": "{{pod}}", "refId": "A"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["shelf", "cache", "trino"],
  "templating": {
    "list": [
      {
        "name": "DS_PROM",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"}
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROM}"},
        "query": "label_values(shelf_hits_total, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Shelf — Overview",
  "uid": "shelf-overview",
  "version": 1,
  "weekStart": ""
}
