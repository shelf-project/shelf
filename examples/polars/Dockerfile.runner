# Polars + PyIceberg runner image for the example.
#
# Pinned versions so cold/warm numbers are reproducible. Polars 1.40
# is the first release in the 1.40 line that ships scan_iceberg with
# the `reader_override` knob.
FROM python:3.11-slim

RUN pip install --no-cache-dir \
        'polars==1.40.1' \
        'pyiceberg[pyarrow,sql-sqlite,s3fs]>=0.9.0,<0.11' \
        'boto3>=1.34,<2'

WORKDIR /app
ENV PYTHONUNBUFFERED=1

CMD ["python", "--version"]
