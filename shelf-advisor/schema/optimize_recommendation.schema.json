{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shelf-project/shelf/shelf-advisor/schema/optimize_recommendation.schema.json",
  "title": "OptimizeRecommendation",
  "description": "OptimizeRecommender (SHELF-53) shape. Narrows the generic Recommendation envelope's `rationale` and `suggested_change` to the small-file detection fields.",
  "allOf": [
    { "$ref": "recommendation.schema.json" },
    {
      "properties": {
        "recommendation_type": { "const": "optimize_targets" },
        "rationale": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "small_file_bytes_threshold",
            "small_files",
            "total_files",
            "small_file_ratio",
            "small_bytes",
            "total_bytes",
            "avg_file_bytes"
          ],
          "properties": {
            "small_file_bytes_threshold": { "type": "integer", "minimum": 0 },
            "small_files": { "type": "integer", "minimum": 0 },
            "total_files": { "type": "integer", "minimum": 1 },
            "small_file_ratio": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "small_bytes": { "type": "integer", "minimum": 0 },
            "total_bytes": { "type": "integer", "minimum": 0 },
            "avg_file_bytes": { "type": "integer", "minimum": 0 }
          }
        },
        "suggested_change": {
          "type": "object",
          "additionalProperties": false,
          "required": ["alter_table", "rewrite_data_files"],
          "properties": {
            "alter_table": { "type": "string" },
            "rewrite_data_files": { "type": "boolean" }
          }
        }
      }
    }
  ]
}
