        "epoch": "1714512345",
        "experiment": "b1_compression_on"
      },
      "wire": "%7B%22cohort%22%3A%22prod_rep1%22%2C%22epoch%22%3A%221714512345%22%2C%22experiment%22%3A%22b1_compression_on%22%7D"
    },
    {
      "name": "non_tag_props_ignored",
