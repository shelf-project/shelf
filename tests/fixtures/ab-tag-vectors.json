        "query_max_memory": "10GB",
        "shelf.tag.experiment": "b1_compression_on",
        "shelf.notatag": "ignored"
      },
      "normalized": {
        "experiment": "b1_compression_on"
      },
      "wire": "%7B%22experiment%22%3A%22b1_compression_on%22%7D"
    }
  ]
