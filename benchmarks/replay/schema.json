{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shelf.io/schemas/benchmarks/replay/v0.json",
  "title": "Shelf replay benchmark result",
  "description": "Authoritative v0.5 gate benchmark (ADR-0010). One record per (backend, run).",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "commit_sha",
    "release_tag",
    "benchmark",
    "backend",
    "config",
    "cluster_shape",
    "trace",
    "samples",
    "summary",
    "gate"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "release_tag": { "type": "string" },
    "benchmark": { "type": "string", "const": "replay" },
    "backend": {
      "type": "string",
      "enum": ["raw-s3", "fs-cache", "alluxio-2-9", "alluxio-3-dora", "shelf"]
    },
    "config": {
      "type": "object",
      "required": ["config_hash", "trino_image", "backend_image"],
      "properties": {
        "config_hash":   { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "trino_image":   { "type": "string" },
        "backend_image": { "type": "string" },
        "plugin_jar_sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "cluster_shape": {
      "type": "object",
      "required": [
        "region",
        "k8s_version",
        "trino_instance_type",
        "trino_worker_count",
        "shelf_instance_type",
        "shelf_node_count"
      ],
      "properties": {
        "region": { "type": "string" },
        "k8s_version": { "type": "string" },
        "trino_instance_type": { "type": "string" },
        "trino_worker_count":  { "type": "integer", "minimum": 1 },
        "shelf_instance_type": { "type": "string" },
        "shelf_node_count":    { "type": "integer", "minimum": 0 },
        "driver_instance_type": { "type": "string" },
        "scale_factor":        { "type": ["number", "null"], "exclusiveMinimum": 0, "maximum": 1 },
        "partial":             { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["source_table", "snapshot_id", "from", "to", "replica", "query_count", "speed"],
      "properties": {
        "source_table": { "type": "string", "const": "cdp.trino_logs.trino_queries" },
        "snapshot_id":  { "type": "string" },
        "from":         { "type": "string", "format": "date-time" },
        "to":           { "type": "string", "format": "date-time" },
        "replica":      { "type": "string", "enum": ["rep-0", "rep-1", "rep-2", "rep-3"] },
        "query_count":  { "type": "integer", "minimum": 0 },
        "speed":        { "type": "string", "enum": ["1x", "2x", "10x"] }
      },
      "additionalProperties": false
    },
    "samples": {
      "type": "array",
      "description": "10-s samples of cumulative hit rate + dbt ok-rate during the replay.",
      "items": {
        "type": "object",
        "required": ["t_seconds", "hit_rate", "gold_dbt_ok_rate"],
        "properties": {
          "t_seconds":        { "type": "number", "minimum": 0 },
          "hit_rate":         { "type": "number", "minimum": 0, "maximum": 1 },
          "gold_dbt_ok_rate": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "latency_ns_p50",
        "latency_ns_p95",
        "latency_ns_p99",
        "latency_ns_p999",
        "hit_rate",
        "bytes_read",
        "bytes_admitted",
        "dollars_per_query"
      ],
      "properties": {
        "latency_ns_p50":  { "type": "integer", "minimum": 0 },
        "latency_ns_p95":  { "type": "integer", "minimum": 0 },
        "latency_ns_p99":  { "type": "integer", "minimum": 0 },
        "latency_ns_p999": { "type": "integer", "minimum": 0 },
        "hit_rate":        { "type": "number", "minimum": 0, "maximum": 1 },
        "bytes_read":      { "type": "integer", "minimum": 0 },
        "bytes_admitted":  { "type": "integer", "minimum": 0 },
        "dollars_per_query": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "gate": {
      "description": "v0.5 gate metrics (ADR-0010). All five must hold for the gate to pass.",
      "type": "object",
      "required": [
        "hit_rate_7d_cumulative",
        "gold_dbt_ok_rate",
        "latency_ns_p95_vs_alluxio",
        "shelf_caused_pages",
        "oncall_surface_ratio",
        "verdict"
      ],
      "properties": {
        "hit_rate_7d_cumulative":   { "type": "number", "minimum": 0, "maximum": 1 },
        "gold_dbt_ok_rate":         { "type": "number", "minimum": 0, "maximum": 1 },
        "latency_ns_p95_vs_alluxio":{ "type": ["number", "null"], "minimum": 0 },
        "shelf_caused_pages":       { "type": "integer", "minimum": 0 },
        "oncall_surface_ratio":     { "type": ["number", "null"], "minimum": 0 },
        "verdict": {
          "type": "string",
          "enum": ["pending", "pass", "fail", "n/a"]
        },
        "failed_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "hit_rate_7d_cumulative",
              "gold_dbt_ok_rate",
              "latency_ns_p95_vs_alluxio",
              "shelf_caused_pages",
              "oncall_surface_ratio"
            ]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
