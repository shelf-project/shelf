{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shelf.io/schemas/benchmarks/spot-churn/v0.json",
  "title": "Shelf spot-churn benchmark result",
  "description": "One record per (backend, run). `samples[]` is the 10-s hit-rate timeseries; `chaos_events[]` is the pod-kill log. See SPEC.md.",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "commit_sha",
    "release_tag",
    "benchmark",
    "backend",
    "config",
    "cluster_shape",
    "samples",
    "chaos_events",
    "summary"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "release_tag": { "type": "string" },
    "benchmark": { "type": "string", "const": "spot-churn" },
    "backend": {
      "type": "string",
      "enum": ["raw-s3", "fs-cache", "alluxio-2-9", "alluxio-3-dora", "shelf"]
    },
    "config": {
      "type": "object",
      "required": ["config_hash", "trino_image", "backend_image"],
      "properties": {
        "config_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "trino_image": { "type": "string" },
        "backend_image": { "type": "string" },
        "plugin_jar_sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "cluster_shape": {
      "type": "object",
      "required": [
        "region",
        "k8s_version",
        "trino_instance_type",
        "trino_worker_count",
        "shelf_instance_type",
        "shelf_node_count"
      ],
      "properties": {
        "region": { "type": "string" },
        "k8s_version": { "type": "string" },
        "trino_instance_type": { "type": "string" },
        "trino_worker_count": { "type": "integer", "minimum": 1 },
        "shelf_instance_type": { "type": "string" },
        "shelf_node_count": { "type": "integer", "minimum": 0 },
        "driver_instance_type": { "type": "string" }
      },
      "additionalProperties": false
    },
    "samples": {
      "type": "array",
      "description": "10-s hit-rate timeseries for the full run.",
      "items": {
        "type": "object",
        "required": ["t_seconds", "hit_rate", "in_flight_queries"],
        "properties": {
          "t_seconds": { "type": "number", "minimum": 0 },
          "hit_rate":  { "type": "number", "minimum": 0, "maximum": 1 },
          "in_flight_queries": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "chaos_events": {
      "type": "array",
      "description": "Timestamps + pods deleted.",
      "items": {
        "type": "object",
        "required": ["t_seconds", "pods_deleted"],
        "properties": {
          "t_seconds": { "type": "number", "minimum": 0 },
          "pods_deleted": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "latency_ns_p50",
        "latency_ns_p95",
        "latency_ns_p99",
        "latency_ns_p999",
        "hit_rate",
        "hit_rate_floor",
        "bytes_read",
        "bytes_admitted",
        "failed_queries_total",
        "dollars_per_query"
      ],
      "properties": {
        "latency_ns_p50":  { "type": "integer", "minimum": 0 },
        "latency_ns_p95":  { "type": "integer", "minimum": 0 },
        "latency_ns_p99":  { "type": "integer", "minimum": 0 },
        "latency_ns_p999": { "type": "integer", "minimum": 0 },
        "hit_rate":        { "type": "number", "minimum": 0, "maximum": 1 },
        "hit_rate_floor":  { "type": "number", "minimum": 0, "maximum": 1 },
        "bytes_read":      { "type": "integer", "minimum": 0 },
        "bytes_admitted":  { "type": "integer", "minimum": 0 },
        "failed_queries_total": { "type": "integer", "minimum": 0 },
        "dollars_per_query": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
